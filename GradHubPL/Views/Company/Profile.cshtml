@{
    ViewBag.Title = "Company Profile";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="container mt-5">

    <div class="card p-4 shadow-sm mb-4">

        <h3>Google</h3>
        <p class="text-muted">Technology Company</p>

        <p>
            Google is a global tech company specializing in internet services,
            AI, and software solutions.
        </p>

    </div>

    <div class="card p-4 shadow-sm">

        <h4>Open Positions</h4>

        <div class="mb-3">
            <h5>Frontend Developer</h5>
            <p class="text-muted">React, TypeScript</p>
            <button class="btn btn-primary">Apply</button>
        </div>

        <div>
            <h5>Backend Engineer</h5>
            <p class="text-muted">.NET, SQL</p>
            <button class="btn btn-primary">Apply</button>
        </div>

    </div>

</section>