@{
    ViewData["Title"] = "Home";
}

<section class="hero">
    <div class="hero-content">

        <div class="left">
            <span class="badge">Trusted by 300+ Companies</span>

            <h1>
                Connect Talent <br />
                With <span>Verified</span> <br />
                Companies
            </h1>

            <p>
                Discover top candidates and hire faster using smart AI filtering.
            </p>

            <div class="search-box">
                <input type="text" placeholder="Search by skill or role" />
                <select>
                    <option>All Categories</option>
                    <option>.NET</option>
                    <option>UI/UX</option>
                </select>
                <button>Search</button>
            </div>
        </div>

        <div class="right">
            <div class="candidate-card">
                <img src="https://randomuser.me/api/portraits/women/44.jpg" />

                <h3>Sarah Chen</h3>
                <p>Senior UX Designer</p>

                <div class="rating">⭐ 5.0</div>

                <a asp-controller="Student" asp-action="Profile" asp-route-id="1">
                    View Profile
                </a>
            </div>
        </div>

    </div>
</section>

<section class="stats">
    <div>
        <i class="fa-solid fa-users"></i>
        <h2>2,000+</h2>
        <p>Candidates</p>
    </div>

    <div>
        <i class="fa-solid fa-building"></i>
        <h2>300+</h2>
        <p>Companies</p>
    </div>

    <div>
        <i class="fa-solid fa-wand-magic-sparkles"></i>
        <h2>AI</h2>
        <p>Filtering</p>
    </div>
</section>

<!-- FEATURED TALENT -->
<section class="featured">
    <h2>Featured Talent</h2>

    <div class="cards">

        @for (int i = 1; i <= 4; i++)
        {
            <div class="profile-card">
                <img src="https://randomuser.me/api/portraits/men/@(20 + i).jpg" />

                <h4>Developer @i</h4>
                <p>.NET Developer</p>

                <a asp-controller="Student"
                   asp-action="Profile"
                   asp-route-id="@i">
                    View Profile
                </a>
            </div>
        }

    </div>
</section>

<!-- AI SECTION -->
<section class="ai-section">

    <div class="ai-left">
        <h2>Talk to your talent pool like never before</h2>
        <p>
            Use AI to filter candidates instantly based on skills,
            experience, and requirements.
        </p>
    </div>

    <div class="ai-right">
        <div class="chat-demo">
            <p><b>You:</b> I need a .NET developer with 2 years experience</p>
            <p><b>AI:</b> Found 3 candidates matching your request</p>
        </div>
    </div>

</section>

<!-- HOW IT WORKS -->
<section class="how">

    <h2>How It Works</h2>

    <div class="steps">

        <div>
            <i class="fa-solid fa-user-plus"></i>
            <h4>Create Profile</h4>
            <p>Upload your CV and skills</p>
        </div>

        <div>
            <i class="fa-solid fa-magnifying-glass"></i>
            <h4>Get Discovered</h4>
            <p>Companies find you easily</p>
        </div>

        <div>
            <i class="fa-solid fa-handshake"></i>
            <h4>Get Hired</h4>
            <p>Connect and start working</p>
        </div>

    </div>

</section>

<!-- CTA -->
<section class="cta">

    <h2>Start your journey today</h2>

    <div class="cta-buttons">

        <a asp-controller="Account" asp-action="StudentRegister">
            Join as Candidate
        </a>

        <a asp-controller="Account" asp-action="CompanyRegister">
            Join as Company
        </a>

    </div>

</section>

<!-- FOOTER -->
<footer class="footer">

    <div class="footer-left">
        <h3>GRADHUB</h3>
        <p>Connecting talent with companies.</p>
    </div>

    <div class="footer-links">
        <a asp-controller="Home" asp-action="Index">Home</a>
        <a asp-controller="Student" asp-action="BrowseCompanies">Candidates</a>
        <a asp-controller="Company" asp-action="BrowseStudents">Companies</a>
        <a asp-controller="Home" asp-action="Privacy">Privacy</a>
    </div>

</footer>