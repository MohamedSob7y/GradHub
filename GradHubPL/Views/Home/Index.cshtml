@{
    ViewBag.Title = "Home";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="hero-section">
    <div class="container">
        <div class="row align-items-center g-4">

            <!-- LEFT -->
            <div class="col-lg-6">
               
                <h1 class="hero-title">
                    Connect Talent With Verified Companies
                </h1>

                <p class="hero-text">
                    Discover top students, explore their skills, and hire faster using smart filtering.
                </p>

                <!-- SEARCH -->
                <div class="row g-2 mt-3">
                    <div class="col-md-5">
                        <input type="text" class="form-control" placeholder="Search by skill" />
                    </div>

                    <div class="col-md-4">
                        <select class="form-control">
                            <option>Select category</option>
                            <option>Frontend</option>
                            <option>Backend</option>
                            <option>UI/UX</option>
                        </select>
                    </div>

                    <div class="col-md-3">
                        <button class="btn btn-primary w-100">Search</button>
                    </div>
                </div>

                <!-- STATS -->
                <div class="row mt-4 text-center">
                    <div class="col">
                        <h4>2K+</h4>
                        <small>Profiles</small>
                    </div>
                    <div class="col">
                        <h4>300+</h4>
                        <small>Companies</small>
                    </div>
                    <div class="col">
                        <h4>Fast</h4>
                        <small>AI Filtering</small>
                    </div>
                </div>

            </div>

            <!-- RIGHT -->
            <div class="col-lg-6 text-center">

                <div class="hero-card">
                    <h5>Top Candidate</h5>
                    <h4>Ahmed Ali</h4>
                    <p>Frontend Developer</p>
                    <p>⭐ 4.8</p>
                    <p class="text-muted">React • JS • Bootstrap</p>
                </div>

            </div>

        </div>
    </div>
</section>

<!-- FEATURED -->
<section class="container mt-5">

    <h2 class="mb-4">Featured Candidates</h2>

    <div class="row">

        <!-- CARD -->
        <div class="col-md-3">
            <div class="candidate-card">
                <h5>Ahmed Ali</h5>
                <p>Frontend Developer</p>
                <p>⭐ 4.8</p>
                <p class="text-muted">React JS</p>
                <button class="btn btn-primary w-100">View</button>
            </div>
        </div>

        <div class="col-md-3">
            <div class="candidate-card">
                <h5>Sara Khaled</h5>
                <p>UI/UX Designer</p>
                <p>⭐ 4.7</p>
                <p class="text-muted">Figma</p>
                <button class="btn btn-primary w-100">View</button>
            </div>
        </div>

        <div class="col-md-3">
            <div class="candidate-card">
                <h5>Omar Hassan</h5>
                <p>.NET Developer</p>
                <p>⭐ 4.9</p>
                <p class="text-muted">C# SQL</p>
                <button class="btn btn-primary w-100">View</button>
            </div>
        </div>

        <div class="col-md-3">
            <div class="candidate-card">
                <h5>Maya Adel</h5>
                <p>Digital Marketer</p>
                <p>⭐ 4.6</p>
                <p class="text-muted">SEO</p>
                <button class="btn btn-primary w-100">View</button>
            </div>
        </div>

    </div>

</section>