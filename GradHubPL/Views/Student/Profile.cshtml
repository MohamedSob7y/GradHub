@{
    ViewBag.Title = "Student Profile";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="container mt-5">

    <div class="row">

        <!-- LEFT -->
        <div class="col-md-4">
            <div class="card p-4 text-center shadow-sm">

                <img src="https://via.placeholder.com/120"
                     class="rounded-circle mb-3"
                     width="120" height="120" />

                <h4>Ahmed Ali</h4>
                <p class="text-muted">Frontend Developer</p>

                <p>⭐ 4.8 Rating</p>

            </div>
        </div>

        <!-- RIGHT -->
        <div class="col-md-8">

            <div class="card p-4 shadow-sm mb-4">
                <h5>About</h5>
                <p>
                    Passionate frontend developer skilled in building responsive
                    and modern web applications using React and JavaScript.
                </p>
            </div>

            <div class="card p-4 shadow-sm mb-4">
                <h5>Skills</h5>
                <span class="badge bg-primary me-2">React</span>
                <span class="badge bg-primary me-2">JavaScript</span>
                <span class="badge bg-primary me-2">Bootstrap</span>
            </div>

            <div class="card p-4 shadow-sm">
                <h5>Projects</h5>

                <div class="mb-3">
                    <h6>Portfolio Website</h6>
                    <p class="text-muted">Personal portfolio using React</p>
                </div>

                <div>
                    <h6>E-commerce UI</h6>
                    <p class="text-muted">Frontend UI for online store</p>
                </div>

            </div>

        </div>

    </div>

</section>